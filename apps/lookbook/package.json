		"react-dom": "19.2.3"
	},
	"devDependencies": {
		"@tailwindcss/postcss": "^4",
		"@types/node": "^20",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"eslint": "^9",
		"eslint-config-next": "16.1.4",
		"postcss": "^8.5.8",
		"tailwindcss": "^4",
		"typescript": "^5"
	},
	"engines": {
		"node": "24.x",
		"pnpm": ">=10.0.0"
