{
	"name": "lookbook",
	"version": "1.1.0-SNAPSHOT",
	"private": true,
	"description": "The interactive design system workbench and component documentation for the portfolio ecosystem.",
	"author": "Otuekong Bassey <otuekong.bassey@gmail.com>",
	"license": "MIT",
	"keywords": [
		"documentation",
		"design-system-workbench",
		"component-playground",
		"lookbook"
	],
	"scripts": {
		"clean": "rm -rf .next node_modules .turbo",
