{
	"compilerOptions": {
		"allowImportingTsExtensions": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"jsx": "preserve",
		"lib": ["ES2020", "DOM", "DOM.Iterable"],
		"module": "ESNext",
		"moduleResolution": "bundler",
		"noEmit": true,
		"paths": {
			"@otuekong-portfolio/archives": ["./packages/archives/src"],
			"@otuekong-portfolio/archives/*": ["./packages/archives/src/*"],
			"@otuekong-portfolio/curio": ["./packages/curio/src"],
			"@otuekong-portfolio/curio/*": ["./packages/curio/src/*"],
			"@otuekong-portfolio/exhibit": ["./packages/exhibit/src"],
			"@otuekong-portfolio/exhibit/*": ["./packages/exhibit/src/*"],
			"@otuekong-portfolio/features": ["./packages/features/src"],
			"@otuekong-portfolio/features/*": ["./packages/features/src/*"],

			"lookbook": ["./apps/lookbook/"],
			"lookbook/*": ["./apps/lookbook/*"],
			"pavilion": ["./apps/pavilion/"],
			"pavilion/*": ["./apps/pavilion/*"],

			"helloworld-classic": ["./apps/galleries/helloworld/classic/"],
			"helloworld-classic/*": ["./apps/galleries/helloworld/classic/*"],
			"helloworld-composite": ["./apps/galleries/helloworld/composite/"],
			"helloworld-composite/*": ["./apps/galleries/helloworld/composite/*"]
		},
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"strict": true,
		"target": "ES2020"
	}
}
