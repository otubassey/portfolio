{
	"name": "@otuekong-portfolio/core",
	"version": "1.0.0",
	"description": "Core business logic package containing all portfolio domains (profile, professional, showroom, contact) and shared utilities. Provides types, components, hooks, and business logic for managing portfolio data.",
	"author": "Otuekong Bassey <otuekong.bassey@gmail.com>",
	"type": "module",
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"license": "MIT",
	"keywords": [
		"components",
		"contact",
		"core",
		"design-system",
		"domains",
		"portfolio",
		"professional",
		"profile",
		"projects",
		"react",
		"typescript",
		"ui"
	],
	"packageManager": "pnpm@10.32.1",
	"exports": {
		".": "./src/index.ts",
		"./contact": "./src/contact/index.ts",
		"./professional": "./src/professional/index.ts",
		"./profile": "./src/profile/index.ts",
		"./showroom": "./src/showroom/index.ts"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"lint": "eslint \"**/*.ts*\"",
		"type-check": "tsc --noEmit"
	},
	"dependencies": {
		"@otuekong-portfolio/common": "workspace:*",
		"@otuekong-portfolio/design-system": "workspace:*"
	},
	"peerDependencies": {
		"react": "19.2.3",
		"react-dom": "19.2.3"
	},
	"devDependencies": {
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"eslint": "^9",
		"typescript": "^5"
	}
}
