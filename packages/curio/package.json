{
	"name": "@otuekong-portfolio/curio",
	"version": "1.0.0-SNAPSHOT",
	"description": "The unified UI foundation for the Otuekong's Portfolio ecosystem. Combines atomic presentational components, design tokens, shared React hooks, and common TypeScript utilities, and developer tooling.",
	"author": "Otuekong Bassey <otuekong.bassey@gmail.com>",
	"type": "module",
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"license": "MIT",
	"keywords": [
		"atoms",
		"components",
		"design-system",
		"foundation",
		"hooks",
		"react",
		"tailwind",
		"tokens",
		"typescript",
		"ui",
		"utilities"
	],
	"packageManager": "pnpm@10.33.1",
	"exports": {
		".": "./src/index.ts",
		"./base": "./src/base.css",
		"./components": "./src/components/index.ts",
		"./hooks": "./src/hooks/externalIndex.ts",
		"./playground": "./src/playground/index.ts",
		"./theme": "./src/theme/index.ts",
		"./utils": "./src/utils/index.ts"
	},
	"files": [
		"dist",
		"src/base.css"
	],
	"scripts": {
		"clean": "rm -rf dist node_modules .turbo",
		"lint": "eslint \"**/*.ts*\"",
		"type-check": "tsc --noEmit"
	},
	"dependencies": {
		"clsx": "^2.1.1",
		"lucide-react": "^0.562.0",
		"react-icons": "^5.5.0",
		"react-shadow": "^20.6.0",
		"tailwind-merge": "^3.4.0"
	},
	"peerDependencies": {
		"react": "19.2.3",
		"react-dom": "19.2.3",
		"tailwindcss": "^4"
	},
	"devDependencies": {
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"typescript": "^5",
		"eslint": "^9"
	}
}
