{
	"name": "@otuekong-portfolio/design-system",
	"version": "0.1.0-SNAPSHOT",
	"description": "A presentational-only library of atomic UI components and design tokens. Built on Tailwind CSS v4 and React 19, this package provides the consistent visual language used across all apps. It includes the standard theme configuration (dark/light), interactive UI primitives, and a meta-tooling playground for component documentation.",
	"author": "Otuekong Bassey <otuekong.bassey@gmail.com>",
	"type": "module",
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"license": "MIT",
	"keywords": [
		"colors",
		"components",
		"design-system",
		"design-tokens",
		"playground",
		"portfolio",
		"react",
		"tailwind",
		"theme",
		"tokens",
		"typography",
		"ui"
	],
	"packageManager": "pnpm@10.32.1",
	"exports": {
		".": "./src/index.ts",
		"./base": "./src/base.css",
		"./components": "./src/components/index.ts",
		"./playground": "./src/playground/index.ts",
		"./theme": "./src/theme/index.ts",
		"./utils": "./src/utils/index.ts"
	},
	"files": [
		"dist",
		"src/base.css"
	],
	"scripts": {
		"lint": "eslint \"**/*.ts*\"",
		"type-check": "tsc --noEmit"
	},
	"dependencies": {
		"@otuekong-portfolio/common": "workspace:*",
		"clsx": "^2.1.1",
		"lucide-react": "^0.562.0",
		"react-icons": "^5.5.0",
		"tailwind-merge": "^3.4.0"
	},
	"peerDependencies": {
		"react": "19.2.3",
		"react-dom": "19.2.3",
		"tailwindcss": "^4"
	},
	"devDependencies": {
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"typescript": "^5",
		"eslint": "^9"
	}
}
